# Copy to .env.local and fill in. Both are public (NEXT_PUBLIC_*) — read by the
# browser when the contact form POSTs the lead to the CRM.

# Where the contact form sends leads (the Align & Acquire CRM contact endpoint).
NEXT_PUBLIC_CRM_URL=https://www.alignandacquire.com/api/contact

# The exact Neon `Business.slug` for this tenant. MUST match the live DB row.
# A wrong slug returns 200 with no DB write = silently lost leads. TODO: paste it.
NEXT_PUBLIC_BUSINESS_SLUG=REPLACE_ME_SLUG
